// ─── NUMÉROLOGIE ─────────────────────────────────────────────────────────────
function reduire(n) {
  while (n > 9 && n !== 11 && n !== 22 && n !== 33) {
    n = String(n).split("").reduce((a, d) => a + parseInt(d), 0);
  }
  return n;
}
function cheminDeVie(dateStr) {
  const [y, m, d] = dateStr.split("-").map(Number);
  return reduire(reduire(d) + reduire(m) + reduire(y));
}
